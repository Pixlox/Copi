{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Copi",
  "version": "0.1.3",
  "identifier": "com.copi.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "overlay",
        "title": "Copi",
        "width": 800,
        "height": 520,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "resizable": false,
        "skipTaskbar": true,
        "center": true,
        "acceptFirstMouse": true,
        "visibleOnAllWorkspaces": true
      },
      {
        "label": "settings",
        "title": "Copi Settings",
        "width": 620,
        "height": 640,
        "minWidth": 480,
        "minHeight": 400,
        "resizable": true,
        "visible": false,
        "center": true,
        "skipTaskbar": false
      },
      {
        "label": "setup",
        "title": "Welcome to Copi",
        "width": 860,
        "height": 620,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "visible": false,
        "center": true,
        "acceptFirstMouse": true,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJBNkExREIzMkVDQ0UwQjQKUldTMDRNd3VzeDFxS3F6Sk5UbXNxTlJsdHVpVllPTTFjYzBNS2l0bGowelozRXhwUTUxU3NhM2UK",
      "endpoints": [
        "https://github.com/Pixlox/copi/releases/latest/download/latest.json"
      ]
    }
  }
}
