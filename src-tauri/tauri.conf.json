{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Copi",
  "version": "0.4.0",
  "identifier": "com.copi.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "overlay",
        "title": "Copi",
        "width": 800,
        "height": 520,
        "minWidth": 800,
        "minHeight": 520,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "resizable": true,
        "skipTaskbar": true,
        "center": true,
        "acceptFirstMouse": true,
        "visibleOnAllWorkspaces": true
      },
      {
        "label": "settings",
        "title": "Copi Settings",
        "width": 720,
        "height": 520,
        "minWidth": 640,
        "minHeight": 420,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": true,
        "resizable": true,
        "visible": false,
        "center": true,
        "skipTaskbar": false
      },
      {
        "label": "setup",
        "title": "Welcome to Copi",
        "width": 860,
        "height": 620,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "visible": false,
        "center": true,
        "acceptFirstMouse": true,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: https://asset.localhost"
    }
  },
  "bundle": {
    "active": true,
    "publisher": "Pixlox",
    "copyright": "Copyright (c) Pixlox",
    "targets": "all",
    "createUpdaterArtifacts": true,
    "windows": {
      "wix": {
        "fragmentPaths": [
          "../../wix/firewall.wxs"
        ],
        "componentGroupRefs": [
          "CopiSyncFirewall"
        ]
      },
      "nsis": {
        "installerHooks": "../../wix/firewall-hooks.nsh"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJBNkExREIzMkVDQ0UwQjQKUldTMDRNd3VzeDFxS3F6Sk5UbXNxTlJsdHVpVllPTTFjYzBNS2l0bGowelozRXhwUTUxU3NhM2UK",
      "endpoints": [
        "https://github.com/Pixlox/copi/releases/latest/download/latest.json"
      ]
    }
  }
}
